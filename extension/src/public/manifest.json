{
    "manifest_version": 3,
    "name": "TIPS-Contest-Extensions",
    "version": "0.1.15",
    "description": "Shared TIPS rooms for LeetCode.",
    "homepage_url": "https://contest.techinterviewprep.support",
    "permissions": ["activeTab", "storage", "tabs", "webRequest"],
    "host_permissions": [
        "https://leetcode.com/problems/*",
        "https://leetcode.com/submissions/detail/*"
    ],
    "action": {
        "default_icon": {
            "16": "icons/16.png",
            "24": "icons/24.png",
            "32": "icons/32.png"
        },
        "default_popup": "popup.html"
    },
    "icons": {
        "16": "icons/16.png",
        "32": "icons/32.png",
        "48": "icons/48.png",
        "128": "icons/128.png"
    },
    "content_scripts": [
        {
            "matches": ["https://leetcode.com/problems/*"],
            "css": ["content.css"],
            "js": ["content.js"]
        },
        {
            "matches": ["https://leetcode.com/*"],
            "exclude_matches": ["https://leetcode.com/problems/*"],
            "css": ["panel.css"],
            "js": ["panel.js"]
        }
    ],
    "background": {
        "service_worker": "background.js"
    }
}
